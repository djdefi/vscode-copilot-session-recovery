{
  "name": "copilot-session-recovery",
  "displayName": "Copilot Session Recovery",
  "description": "Recover stuck or broken Copilot Chat sessions, export chat history, and restore pending file edits",
  "version": "0.1.0",
  "publisher": "djdefi",
  "repository": {
    "type": "git",
    "url": "https://github.com/djdefi/vscode-copilot-session-recovery"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "recovery",
    "chat",
    "session",
    "backup"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilot-recovery.listSessions",
        "title": "List All Sessions",
        "category": "Copilot Recovery",
        "icon": "$(list-unordered)"
      },
      {
        "command": "copilot-recovery.showSession",
        "title": "Show Session Details",
        "category": "Copilot Recovery",
        "icon": "$(info)"
      },
      {
        "command": "copilot-recovery.exportSession",
        "title": "Export Chat History",
        "category": "Copilot Recovery",
        "icon": "$(export)"
      },
      {
        "command": "copilot-recovery.recoverFiles",
        "title": "Recover Pending Files",
        "category": "Copilot Recovery",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "copilot-recovery.fixSession",
        "title": "Fix Stuck Session",
        "category": "Copilot Recovery",
        "icon": "$(wrench)"
      },
      {
        "command": "copilot-recovery.backupSession",
        "title": "Backup Session",
        "category": "Copilot Recovery",
        "icon": "$(archive)"
      },
      {
        "command": "copilot-recovery.refresh",
        "title": "Refresh Sessions",
        "category": "Copilot Recovery",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilot-recovery",
          "title": "Copilot Recovery",
          "icon": "$(history)"
        }
      ]
    },
    "views": {
      "copilot-recovery": [
        {
          "id": "copilotRecovery.sessions",
          "name": "Chat Sessions",
          "contextualTitle": "Copilot Session Recovery"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "copilot-recovery.refresh",
          "when": "view == copilotRecovery.sessions",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "copilot-recovery.showSession",
          "when": "view == copilotRecovery.sessions",
          "group": "inline@1"
        },
        {
          "command": "copilot-recovery.exportSession",
          "when": "view == copilotRecovery.sessions",
          "group": "1_actions@1"
        },
        {
          "command": "copilot-recovery.recoverFiles",
          "when": "view == copilotRecovery.sessions && viewItem == session-with-edits",
          "group": "1_actions@2"
        },
        {
          "command": "copilot-recovery.fixSession",
          "when": "view == copilotRecovery.sessions && viewItem == session-stuck",
          "group": "1_actions@3"
        },
        {
          "command": "copilot-recovery.backupSession",
          "when": "view == copilotRecovery.sessions",
          "group": "2_backup@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2"
  }
}
